rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety net default block
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth validation helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth != null && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == "faizudemon@gmail.com"
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "faizudemon@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. News Articles collection
    match /news/{newsId} {
      allow read: if true; // News articles are readable by the public
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Non-admins can update views or bookmarksCount fields only
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'bookmarksCount']) &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.summary == resource.data.summary
      );
    }

    // 2. News Sources collection
    match /sources/{sourceId} {
      allow read: if true; // Public list of sources for credibility checks
      allow write: if isAdmin();
    }

    // 3. Advertisements collection
    match /ads/{adId} {
      allow read: if true; // Publicly served ads
      allow write: if isAdmin();
    }

    // 4. Misinformation Reports collection
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone (even anonymous or unverified users) can report fake news
      allow update, delete: if isAdmin();
    }

    // 5. Admins list
    match /admins/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
